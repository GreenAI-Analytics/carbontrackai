{
  "project_id": "carbontrackai-local",
  "db": {
    "shadow_database_url": "postgresql://postgres:postgres@localhost:54322/postgres"
  },
  "api": {
    "port": 54321,
    "schemas": ["public", "graphql_public"],
    "extra_search_path": ["public", "extensions"],
    "max_rows": 1000
  },
  "auth": {
    "enable_signup": true,
    "email": {
      "enable_confirmations": false
    }
  },
  "realtime": {
    "enabled": true,
    "max_bytes_per_second": 1048576,
    "max_connections": 100,
    "max_joins_per_second": 100,
    "max_presence_channels": 1000,
    "max_presence_users_per_channel": 1000,
    "max_push_channels": 1000,
    "max_push_messages_per_second": 100
  },
  "studio": {
    "port": 54323,
    "enabled": true
  },
  "inbucket": {
    "enabled": true,
    "port": 54324,
    "smtp_port": 54325
  }
}
