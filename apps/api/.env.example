# =============================================================================
# ESG TrackAI — API Backend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values:
#   cp apps/api/.env.example apps/api/.env.local
#
# For local Supabase development, run: supabase start
# Then copy the anon_key and service_role_key from the output.
# =============================================================================

# ─── Supabase (Required) ──────────────────────────────────────────────────────
# URL of your Supabase project
SUPABASE_URL=

# Supabase anon/public key — safe for client-side use, limited by RLS
SUPABASE_ANON_KEY=

# Supabase service_role key — admin access, bypasses RLS. NEVER expose in frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Emission Factors (ESRS E1) ────────────────────────────────────────────────
# Climatiq API key — free tier available at https://www.climatiq.io
# Used for: EU27 emission factor lookups, EEA grid factors
CLIMATIQ_API_KEY=

# ADEME Base Carbone (France) — free public API, 10 calls/sec/IP limit
# Used for: country-specific emission factors (France)
# Endpoint: https://data.ademe.fr/api-base-carbone
ADEME_API_KEY=

# MITECO (Spain) — OpenAPI datastore, public access
# Used for: country-specific emission factors (Spain)
# Endpoint: https://catalogo.datosabiertos.miteco.gob.es
MITECO_API_KEY=

# ─── Social Benchmarks (ESRS S1–S4) ──────────────────────────────────────────
# Optional: Database or API URL for country-specific social benchmarking data
# e.g. average training hours by sector, gender pay gap by country
SOCIAL_BENCHMARK_DB_URL=

# ─── ESRS Taxonomy & Datapoints ───────────────────────────────────────────────
# Optional: ESRS datapoint taxonomy registry (for auto-mapping disclosures)
# Can point to a local JSON seed file or an external API
ESRS_DATAPOINT_API_URL=

# ─── EU Taxonomy ───────────────────────────────────────────────────────────────
# Optional: EU Taxonomy screening criteria (NACE/technical screening)
# Used for: substantial contribution, DNSH, minimum safeguards checks
EU_TAXONOMY_API_URL=

# ─── External Data Sources (Optional) ─────────────────────────────────────────
# Eurostat FIGARO — for spend-based Scope 3 (MRIO tables)
# Endpoint: https://ec.europa.eu/eurostat/api
EUROSTAT_API_KEY=

# AIB Residual Mix — for market-based Scope 2 (residual grid factors)
# Endpoint: https://www.aib-net.org/portal
AIB_MEMBERSHIP_ID=

# ─── Supabase Local Development (Override for local Supabase) ──────────────────
# When running Supabase locally via `supabase start`, the local credentials
# are typically:
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Uncomment these lines to override:
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable premium ESG modules in local development
# (These are normally gated by feature_flag_subscriptions in the database)
ESG_E2_POLLUTION_ENABLED=true
ESG_E3_WATER_ENABLED=true
ESG_E4_BIODIVERSITY_ENABLED=true
ESG_E5_CIRCULAR_ENABLED=true
ESG_S1_WORKFORCE_ENABLED=true
ESG_S2_VALUECHAIN_ENABLED=true
ESG_S3_COMMUNITIES_ENABLED=true
ESG_S4_CONSUMERS_ENABLED=true
ESG_G1_BUSINESS_CONDUCT_ENABLED=true
ESG_MATERIALITY_ENABLED=true
ESG_TAXONOMY_ENABLED=true
