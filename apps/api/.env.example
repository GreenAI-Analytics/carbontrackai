# Supabase Configuration Template
# Copy this file to .env.local and fill in your actual credentials

# Supabase Connection Details
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Studio - Admin Interface
SUPABASE_STUDIO_URL=http://localhost:54323

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Application Settings
NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
API_EXTERNAL_TIMEOUT_MS=9000

# Email Service (Resend)
RESEND_API_KEY=

# Add project-specific environment variables below
# CLIMATIQ_API_KEY=
# EMISSION_FACTOR_SOURCE=
