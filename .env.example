# =============================================================================
# ESG TrackAI — Root Environment Configuration
# =============================================================================
# Copy this file to `.env.local` and fill in your actual values.
#
#   cp .env.example .env.local
#
# NEVER commit .env.local or any file containing real credentials.
# =============================================================================


# ──────────────────────────────────────────────────────────────────────────────
# SUPABASE — Authentication & Database
# ──────────────────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard: Settings → API
# For local Supabase CLI, run `supabase start` and copy the output values.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ──────────────────────────────────────────────────────────────────────────────
# FRONTEND — Next.js Public Variables (must be prefixed with NEXT_PUBLIC_)
# ──────────────────────────────────────────────────────────────────────────────
# These are exposed to the browser. Only put public-safe values here.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="ESG TrackAI"


# ──────────────────────────────────────────────────────────────────────────────
# EMISSION FACTORS — Third-Party Data Providers (ESRS E1)
# ──────────────────────────────────────────────────────────────────────────────
# Climatiq:     https://app.climatiq.io       (free tier available)
# ADEME:        https://data.ademe.fr         (France, free public API)
# MITECO:       https://datosabiertos.miteco.gob.es (Spain, public API)

CLIMATIQ_API_KEY=
# ADEME_API_KEY=
# MITECO_API_KEY=


# ──────────────────────────────────────────────────────────────────────────────
# ESRS TAXONOMY — European Sustainability Reporting Standards
# ──────────────────────────────────────────────────────────────────────────────
# EFRAG ESRS Datapoint API (check availability)

# ESRS_DATAPOINT_API_URL=
# ESRS_DATAPOINT_API_KEY=


# ──────────────────────────────────────────────────────────────────────────────
# SOCIAL BENCHMARKING — Country-Specific Social Metrics (ESRS S1–S4)
# ──────────────────────────────────────────────────────────────────────────────
# Eurostat / OECD data for benchmarking workforce, diversity, pay gap, etc.

# SOCIAL_BENCHMARK_DB_URL=


# ──────────────────────────────────────────────────────────────────────────────
# EU TAXONOMY — Regulatory Technical Standards Data
# ──────────────────────────────────────────────────────────────────────────────
# Delegated acts / technical screening criteria lookups.

# TAXONOMY_API_URL=


# ──────────────────────────────────────────────────────────────────────────────
# AI / LLM — ESG Narrative Generation (optional)
# ──────────────────────────────────────────────────────────────────────────────
# For generating CSRD report narratives and decarbonisation recommendations.

# AI_PROVIDER=openai
# AI_API_KEY=
# AI_MODEL=gpt-4o


# ──────────────────────────────────────────────────────────────────────────────
# STORAGE — File Uploads & Report Exports (S3-compatible)
# ──────────────────────────────────────────────────────────────────────────────
# For CSV/Excel activity data imports and generated CSRD report exports.

# STORAGE_ENDPOINT=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_BUCKET=esg-trackai-exports
# STORAGE_REGION=eu-west-1


# ──────────────────────────────────────────────────────────────────────────────
# APPLICATION — General Configuration
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
# SESSION_SECRET=
# ENCRYPTION_KEY=


# ──────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT — Vercel
# Get these from https://vercel.com/account/tokens

VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=


# MONITORING — Error Tracking (optional)
# ──────────────────────────────────────────────────────────────────────────────

# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=


# ──────────────────────────────────────────────────────────────────────────────
# QUICK START
# ──────────────────────────────────────────────────────────────────────────────
#   1. cp .env.example .env.local
#   2. Fill in SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY
#   3. (Optional) Add CLIMATIQ_API_KEY for live emission factors
#   4. npm install && npm run dev
#
# Minimum viable config for local development:
#   SUPABASE_URL + SUPABASE_ANON_KEY + SUPABASE_SERVICE_ROLE_KEY
#   NEXT_PUBLIC_SUPABASE_URL + NEXT_PUBLIC_SUPABASE_ANON_KEY
