{
  "name": "carbontrackai",
  "version": "1.0.0",
  "description": "VSME-aligned carbon accounting platform for EU SMEs.",
  "main": "index.js",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev -w @carbontrackai/web",
    "dev:api": "npm run dev -w @carbontrackai/api",
    "dev:all": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GreenAI-Analytics/carbontrackai.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/GreenAI-Analytics/carbontrackai/issues"
  },
  "homepage": "https://github.com/GreenAI-Analytics/carbontrackai#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
